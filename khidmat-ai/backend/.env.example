# Khidmat AI — Environment Variables
# Copy this to .env and fill in your keys

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Google Maps Platform
GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Twilio (WhatsApp, SMS, Voice)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Polygon Amoy Testnet (Blockchain)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
WALLET_PRIVATE_KEY=your_test_wallet_private_key

# JazzCash Sandbox
JAZZCASH_MERCHANT_ID=your_jazzcash_sandbox_id
JAZZCASH_PASSWORD=your_jazzcash_sandbox_password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Cloudinary (media hosting)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key

# SendGrid (email)
SENDGRID_API_KEY=your_sendgrid_key

# App
DEBUG=true
HOST=0.0.0.0
PORT=8000
